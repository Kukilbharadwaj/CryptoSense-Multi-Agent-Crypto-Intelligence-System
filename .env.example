# CryptoSense Environment Configuration
# =======================================

# Required: Groq API key for LLM inference
GROQ_API_KEY=your_groq_api_key_here

# Optional: Langfuse monitoring (https://cloud.langfuse.com)
# Create a project at langfuse.com and copy the keys
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxx
LANGFUSE_HOST=https://cloud.langfuse.com

# Optional: DeepEval (only needed for LLM-as-judge evaluation)
# OPENAI_API_KEY=sk-xxxxxxxx
